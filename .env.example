# 실제 키는 .env에만 둔다 (.env는 gitignore + Claude Code 훅이 편집 차단).
# 모든 변수가 선택값 — 아무것도 없어도 offline lane은 동작한다.

# real lane (인덱스 빌드·평가·judge에 OpenAI 호출 — 비용 발생)
OPENAI_API_KEY=sk-...

# 모델 오버라이드 (기본값: embedding text-embedding-3-small / generation gpt-5.4-mini / judge gpt-5.4-mini)
# RFP_EMBEDDING_MODEL=text-embedding-3-small
# RFP_GENERATION_MODEL=gpt-5.4-mini
# RFP_JUDGE_MODEL=gpt-5.4-mini

# Langfuse 트레이싱 (둘 다 있어야 활성화 — 없으면 완전한 no-op)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com  # self-host/리전 인스턴스일 때만 지정

# open lane (저비용 이터레이션 — 게이트 증거 아님, ADR-0005)
# 생성 기본: DeepSeek deepseek-v4-flash / 임베딩 기본: 로컬 Ollama bge-m3 (키 불필요)
DEEPSEEK_API_KEY=sk-...
# RFP_OPEN_BASE_URL=https://api.deepseek.com   # Ollama 백업: http://localhost:11434/v1
# RFP_OPEN_MODEL=deepseek-v4-flash             # Ollama 백업: qwen3:8b
# RFP_OPEN_API_KEY=                            # 미설정 시 DEEPSEEK_API_KEY 사용
# RFP_OPEN_EMBEDDING_BASE_URL=http://localhost:11434/v1
# RFP_OPEN_EMBEDDING_MODEL=bge-m3

# judge를 OpenAI 호환 백엔드로 돌리는 오버라이드 (A/B: scripts/judge_ab.py)
# 임베딩(answer_relevancy)은 OpenAI 유지 — OPENAI_API_KEY는 여전히 필요
# RFP_JUDGE_BASE_URL=https://api.deepseek.com
# RFP_JUDGE_API_KEY=
