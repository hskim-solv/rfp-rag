# 실제 키는 .env에만 둔다 (.env는 gitignore + Claude Code 훅이 편집 차단).
# 모든 변수가 선택값 — 아무것도 없어도 offline lane은 동작한다.

# real lane (인덱스 빌드·평가·judge에 OpenAI 호출 — 비용 발생)
OPENAI_API_KEY=sk-...

# 모델 오버라이드 (기본값: embedding text-embedding-3-small / generation gpt-5.4-mini / judge gpt-5.4)
# RFP_EMBEDDING_MODEL=text-embedding-3-small
# RFP_GENERATION_MODEL=gpt-5.4-mini
# RFP_JUDGE_MODEL=gpt-5.4

# Langfuse 트레이싱 (둘 다 있어야 활성화 — 없으면 완전한 no-op)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com  # self-host/리전 인스턴스일 때만 지정
